# Copy this file to `.env` and fill in real values.
# Never commit `.env` — it's already in .gitignore.
#
# Get these from https://www.strava.com/settings/api after creating your
# personal API application. The client_id is public; the client_secret is
# sensitive — keep it local only.

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Filled in automatically by exchange_code.py after the one-time OAuth exchange.
STRAVA_REFRESH_TOKEN=
