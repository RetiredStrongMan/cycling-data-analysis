# Copy this file to `.env` and fill in real values.
# Never commit `.env` — it's already in .gitignore.
#
# Get these from https://www.strava.com/settings/api after creating your
# personal API application. The client_id is public; the client_secret is
# sensitive — keep it local only.

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# For the local CLI tools only (sync/backfill scripts). The web app uses
# per-user refresh tokens stored in the database after each user signs in.
STRAVA_REFRESH_TOKEN=

# Used to sign session cookies for the Flask app. Set this in production to
# a stable random string so sessions survive process restarts. In local dev
# you can leave it blank and one will be generated each time the app starts.
SECRET_KEY=

# Set to 1 in production (HTTPS) so the session cookie is only sent over TLS.
SESSION_COOKIE_SECURE=0

# Strava webhook verify token. Used during one-time subscription handshake.
# Generate with `openssl rand -hex 16` and use the same value in the
# POST /push_subscriptions call when you set up webhooks after deploy.
STRAVA_VERIFY_TOKEN=

# Public hostname Caddy will request a Let's Encrypt cert for (VPS deploy only).
# Must already have an A record pointing at this server's public IP.
DOMAIN_NAME=
